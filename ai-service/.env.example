# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=

# ── Embedding model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/e5-base-v2
EMBEDDING_DIM=768

# ── Service ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ── Security ──────────────────────────────────────────────────────────────────
# Must match AI_SERVICE_API_KEY in the Node.js backend .env
API_KEY=
