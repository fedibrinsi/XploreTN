{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": "src",
    "outDir": "./dist",
    "strict": false,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "prisma/**/*"
  ]
}