generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

model User {
  id                       Int                       @id @default(autoincrement())
  email                    String                    @unique
  createdAt                DateTime                  @default(now())
  fullName                 String
  image                    String?
  password                 String
  role                     Role                      @default(TOURISTE)
  bio                      String?
  review                   String?
  rating                   Int?

  interests     String[]
  embeddingText String                      @default("")
  embedding     Unsupported("vector(768)")?
  activities               Activity[]
  activityReservations     ActivityReservation[]
  conversationParticipants ConversationParticipant[]
  housings                 Housing[]
  messages                 Message[]
  reservations             Reservation[]
  notificationHousings     NotificationHousing[]
  notificationActivities   NotificationActivity[]
}

model Activity {
  id          Int              @id @default(autoincrement())
  title       String
  description String
  price       Float
  date        DateTime
  location    String
  latitude    Float
  longitude   Float
  images      String[]
  status      ActivityStatus   @default(APPROVED)
  capacity    Int
  category    ActivityCategory
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  creatorId   Int
  creator     User             @relation(fields: [creatorId], references: [id])
  activityReservations   ActivityReservation[]
  notificationActivities NotificationActivity[]

  tags          String[]
  embeddingText String                      @default("")
  embedding     Unsupported("vector(768)")?

  @@unique([title, creatorId])
  @@index([location])
  @@index([date])
  @@index([category])
  @@index([status])
  @@index([creatorId])
}

model Housing {
  id                   String                @id @default(uuid())
  title                String
  description          String
  location             String
  type                 HousingType
  floors               Int
  rooms                Int
  familyMembers        Int
  maxTourists          Int
  maxStayDays          Int
  images               String[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  ownerId              Int
  latitude             Float                 @default(36.8065)
  longitude            Float                 @default(10.1815)
  owner                User                  @relation(fields: [ownerId], references: [id])
  reservations         Reservation[]
  notificationHousings NotificationHousing[]
}

model Place {
  id           String        @id @default(cuid())
  name         String
  category     PlaceCategory
  address      String
  city         String
  latitude     Float
  longitude    Float
  rating       Float?
  reviewCount  Int?
  isOpen       Boolean?
  openingHours Json?
  phone        String?
  website      String?
  tags         String[]
  images       String[]
  description  String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  embeddingText String                      @default("")
  embedding     Unsupported("vector(768)")?

  @@unique([name, city])
  @@index([latitude, longitude])
  @@index([category])
  @@index([city])
}

model Conversation {
  id           String                    @id @default(uuid())
  type         String
  name         String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  conversationId String
  userId         Int
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       Int
  text           String
  createdAt      DateTime     @default(now())
  readBy         String[]
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Reservation {
  id                   String                @id @default(uuid())
  housingId            String
  touristId            Int
  status               ReservationStatus     @default(PENDING)
  startDate            DateTime
  endDate              DateTime
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  housing              Housing               @relation(fields: [housingId], references: [id], onDelete: Cascade)
  tourist              User                  @relation(fields: [touristId], references: [id], onDelete: Cascade)
  notificationHousings NotificationHousing[]

  @@index([housingId])
  @@index([touristId])
  @@index([status])
}

model ActivityReservation {
  id                     String                 @id @default(uuid())
  activityId             Int
  touristId              Int
  guests                 Int                    @default(1)
  notes                  String?
  status                 ReservationStatus      @default(PENDING)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  activity               Activity               @relation(fields: [activityId], references: [id], onDelete: Cascade)
  tourist                User                   @relation(fields: [touristId], references: [id], onDelete: Cascade)
  notificationActivities NotificationActivity[]

  @@index([activityId])
  @@index([touristId])
  @@index([status])
}

enum Role {
  CITOYEN
  TOURISTE
}

enum ActivityStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActivityCategory {
  ART_HERITAGE
  GASTRONOMY
  COASTAL_ESCAPE
  HISTORICAL_TOUR
  ARTISAN_WORKSHOP
  DESERT_EXPEDITION
  NATURE_ADVENTURE
  CULTURAL_EVENT
  WELLNESS
  OTHER
}

enum HousingType {
  APARTMENT
  VILLA
  STUDIO
  TRADITIONAL_HOUSE
  FARM_STAY
  GUESTHOUSE
  RIAD
  CHALET
}

enum PlaceCategory {
  RESTAURANT
  CAFE
  TEA_HOUSE
  SHOP
  BEAUTY_SALON
  PHARMACY
  BAKERY
  MARKET
}

enum ReservationStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

model NotificationHousing {
  id            String                  @id @default(uuid())
  userId        Int
  housingId     String
  reservationId String
  type          NotificationHousingType
  isRead        Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  housing       Housing                 @relation(fields: [housingId], references: [id], onDelete: Cascade)
  reservation   Reservation             @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([housingId])
  @@index([isRead])
}

model NotificationActivity {
  id            String                   @id @default(uuid())
  userId        Int
  activityId    Int
  reservationId String
  type          NotificationActivityType
  isRead        Boolean                  @default(false)
  createdAt     DateTime                 @default(now())
  user          User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity      Activity                 @relation(fields: [activityId], references: [id], onDelete: Cascade)
  reservation   ActivityReservation      @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([activityId])
  @@index([isRead])
}

enum NotificationHousingType {
  RESERVATION_REQUESTED // owner reçoit : un touriste a demandé une réservation
  RESERVATION_ACCEPTED // touriste reçoit : sa réservation a été acceptée
  RESERVATION_REJECTED // touriste reçoit : sa réservation a été refusée
  RESERVATION_CANCELLED // owner reçoit : un touriste a annulé sa réservation
  RESERVATION_COMPLETED // touriste reçoit : son séjour est marqué comme terminé
}

enum NotificationActivityType {
  RESERVATION_REQUESTED // creator reçoit : un touriste a demandé une réservation
  RESERVATION_ACCEPTED // touriste reçoit : sa réservation a été acceptée
  RESERVATION_REJECTED // touriste reçoit : sa réservation a été refusée
  RESERVATION_CANCELLED // creator reçoit : un touriste a annulé sa réservation
  RESERVATION_COMPLETED // touriste reçoit : son activité est marquée comme terminée
}
